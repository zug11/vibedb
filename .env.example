# VibeDB local development
#
# Copy this file to .env and fill in the values you need.
# Do not commit .env or real provider credentials.

# Local AI proxy used by `npm run dev`.
# The key is read by the Vite dev server and is not exposed to the browser.
OPENAI_API_KEY=

# Optional: use a separate key for parallel per-table generation.
# Leave blank to reuse OPENAI_API_KEY.
OPENAI_API_KEY_PARALLEL=

# Model routing for the local AI proxy and Tauri desktop bridge.
OPENAI_BLUEPRINT_MODEL=gpt-5.5
OPENAI_PARALLEL_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0.2

# Frontend AI endpoint.
# Browser dev defaults to /api/vibedb-ai.
# Hosted or packaged builds can point this at a deployed proxy/edge function.
VITE_AI_ENDPOINT=/api/vibedb-ai

# Optional Supabase project used for auth, cloud saves, deployments, and edge functions.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Production Supabase edge functions use secrets configured through Supabase, not this file:
#   supabase secrets set ANTHROPIC_API_KEY=...
#   supabase secrets set STRIPE_SECRET_KEY=...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=...
